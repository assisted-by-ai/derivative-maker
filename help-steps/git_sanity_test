## Single-source git verification tool. Verifies signatures, tag status, and
## working-tree cleanliness for the main repo and recursively for all
## submodules. Used by 'derivative-update' and 'build-steps.d/1100_sanity-tests',
## and runnable standalone by developers.
##
## Usage:
##   help-steps/git_sanity_test [--mode MODE] [options]
##
##   With no arguments, defaults to '--mode all --context "main repo"',
##   which verifies the current repository (main repo + all submodules)
##   with the standard set of checks (signature, tag status, uncommitted).
##
## Modes:
##
##   --mode all --context LABEL
##     'working-tree' on the current directory, then 'submodules'.
##     This is the default when no '--mode' is given.
##
##   --mode working-tree --context LABEL
##     Verify the current working directory's git repo:
##       1. sq-git signature on HEAD commit
##       2. sq-git signature on the tag object (if HEAD is an exact tag)
##       3. untagged commit check
##       4. uncommitted changes check
##     Exit codes: 0=ok, 1=signature, 2=untagged, 3=uncommitted
##
##   --mode ref --ref REF --ref-type {tag|commit}
##     Verify a specific ref's signature(s) only.
##       - Always checks the commit signature.
##       - For --ref-type tag, also checks the tag object signature.
##     Exit codes: 0=ok, 1=verification failed
##
##   --mode submodules
##     Recursively run 'working-tree' on every submodule via
##     'git submodule foreach --recursive'. Submodules use --trust-root HEAD
##     because the parent repo (already verified) pins each submodule commit.
##     Exit codes: 0=ok, non-zero=at least one submodule failed
##
##   --help, -h
##     Print this usage information and exit.
##
## Forwarded arguments:
##   Any argument that is not in the script-specific list above
##   (--mode/--context/--ref/--ref-type/--help) is forwarded to
##   'help-steps/parse-cmd' via 'help-steps/variables' during the
##   standalone bootstrap. This is the same parser the build-step
##   scripts use, so you can pass e.g.:
##
##     ./help-steps/git_sanity_test --allow-untagged true
##     ./help-steps/git_sanity_test --allow-uncommitted true
##
##   Forwarding only takes effect when the script is invoked standalone
##   (env vars not yet set). When invoked from a build context where the
##   parent has already populated the env vars, forwarded arguments are
##   ignored with a warning - the parent's parse-cmd run already set the
##   relevant env vars.
##
## Environment variables (all REQUIRED for security; no implicit defaults):
##
##   sq_git_policy_file
##     REQUIRED. Absolute path to the openpgp-policy.toml policy file.
##     Set in 'help-steps/variables'.
##
##   sq_git_trust_root
##     REQUIRED. Trust root for 'sq-git log --trust-root'. Caller must
##     decide explicitly. 'help-steps/variables' sets this based on build
##     mode (HEAD for CI / non-redistributable, a fixed commit hash for
##     redistributable builds). For --mode submodules, this script
##     internally overrides to "HEAD" because the parent repo (already
##     verified) pins each submodule commit.
##
##   dist_build_ignore_untagged
##     REQUIRED. "true" or "false". Whether to skip the untagged check.
##     Set by 'help-steps/parse-cmd' from --allow-untagged; defaulted to
##     "false" by 'help-steps/variables' otherwise.
##
##   dist_build_ignore_uncommitted
##     REQUIRED. "true" or "false". Whether to skip the uncommitted check.
##     Set by 'help-steps/parse-cmd' from --allow-uncommitted; defaulted to
##     "false" by 'help-steps/variables' otherwise.
##
## Optional environment variables:
##
##   dist_source_help_steps_folder
##     Used only to print a 'cleanup-files' hint on uncommitted-changes
##     failure. If unset, the hint is omitted.
##
## Standalone use:
##   When invoked directly by a developer (env vars not yet set), this
##   script sources 'help-steps/pre', 'help-steps/colors', and
##   'help-steps/variables' to populate the required env vars - the same
##   way 'derivative-update' and 'build-steps.d/*' do. This makes the
##   script Just Work when run from a freshly cloned working tree:
##
##     cd derivative-maker
##     ./help-steps/git_sanity_test
##
##   When invoked from a build context (env vars already set), this
##   script does NOT re-source the build infrastructure.

set -e
set -o pipefail

MYDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

## ----------------------------------------------------------------------------
## Argument parsing
## ----------------------------------------------------------------------------
##
## Two layers:
##  1. Script-specific args (--mode/--context/--ref/--ref-type/--help)
##     are parsed here and consumed.
##  2. Anything else (e.g. --allow-untagged true, --allow-uncommitted true,
##     --debug) is forwarded to 'help-steps/parse-cmd' via 'help-steps/
##     variables' during the standalone bootstrap below. This avoids
##     duplicating parse-cmd's argument vocabulary in this script.
##
## NOTE: Forwarding only takes effect during the standalone bootstrap, i.e.
## when env vars are not yet set. When invoked from a build context (env
## vars already exported and inherited from the parent), the parent's
## parse-cmd invocation has already populated the env vars; passing
## --allow-* directly to this script in that situation has no effect.

mode=""
context=""
ref=""
ref_type=""
forwarded_args=()

print_help() {
   ## Print the leading doc comments (## ...) at the top of this file,
   ## stopping at the first non-comment, non-blank line. Skips the shebang
   ## and any single-# lines.
   awk '
      NR == 1 && /^#!/   { next }
      /^##/              { sub(/^## ?/, ""); print; next }
      /^[[:space:]]*$/   { print; next }
      { exit }
   ' "$0"
}

while [ $# -gt 0 ]; do
   case "$1" in
      --mode)      mode="${2:-}";     shift 2 ;;
      --context)   context="${2:-}";  shift 2 ;;
      --ref)       ref="${2:-}";      shift 2 ;;
      --ref-type)  ref_type="${2:-}"; shift 2 ;;
      --help|-h)   print_help; exit 0 ;;
      ## Everything else: forward to parse-cmd via the standalone bootstrap.
      ## Most arguments parse-cmd accepts come in '--name value' pairs;
      ## we forward both tokens together. Bare flags would also work
      ## because parse-cmd's case statement consumes its own tokens.
      *)
         if [ $# -ge 2 ]; then
            forwarded_args+=("$1" "$2")
            shift 2
         else
            forwarded_args+=("$1")
            shift
         fi
         ;;
   esac
done

## Default mode: when run with no '--mode', do the most thorough check
## (main repo + all submodules). This is the safest default.
[ -n "$mode" ] || mode="all"
case "$mode" in
   all|working-tree)
      [ -n "$context" ] || context="main repo"
      ;;
esac

## ----------------------------------------------------------------------------
## Standalone-use bootstrap: source build infrastructure if env vars unset.
## ----------------------------------------------------------------------------
##
## When invoked from 'derivative-update' or 'build-steps.d/1100_sanity-tests',
## the build infrastructure has already been sourced and the env vars are
## inherited (because they are exported). When invoked directly by a
## developer, the env vars are unset; we source 'pre', 'colors', and
## 'variables' here to populate them - the same scripts the normal callers
## source.
##
## Why conditional (and not the standard help-steps unconditional pattern):
## sourcing 'help-steps/variables' executes 'cd "$source_code_folder_dist"'
## (variables line ~121), which moves the cwd to the main repo. When this
## script is invoked recursively via 'git submodule foreach' (--mode
## submodules below), the cwd is the submodule directory and must stay
## there for 'git rev-parse HEAD' / 'git status' to operate on the
## submodule. Skipping the sourcing in that case (env vars are already
## inherited from the parent) preserves the cwd.
##
## We forward unrecognized command-line args (e.g. --allow-untagged true,
## --allow-uncommitted true, --debug) to 'help-steps/parse-cmd' via 'help-
## steps/variables'. variables sources parse-cmd and calls
## 'dist_build_one_parse_cmd "$@"' with whatever positional parameters are
## set when variables is sourced - so we 'set --' to our forwarded_args
## first. This avoids duplicating parse-cmd's argument parsing here.
##
## 'dist_build_internal_run="true"' tells parse-cmd to accept being
## invoked with zero or unknown args without exiting (it would otherwise
## reject empty argv as "No option chosen!").
##
## NOTE: 'pre' disables 'set -e' and installs ERR/EXIT traps for build-step
## error handling. Our explicit 'exit N' calls still propagate via pre's
## EXIT trap. Unexpected command failures are caught by pre's ERR trap.
if [ -z "${sq_git_policy_file:-}" ]; then
   set -- "${forwarded_args[@]}"
   dist_build_internal_run="true"
   source "$MYDIR/pre"
   source "$MYDIR/colors"
   source "$MYDIR/variables"
elif [ "${#forwarded_args[@]}" -gt 0 ]; then
   ## Build-context invocation: env vars are already set, but the user
   ## passed extra args meant for parse-cmd. Warn that they will be
   ## ignored - the parent build context's parse-cmd run already set
   ## the env vars and we cannot re-run parse-cmd here without sourcing
   ## the build infrastructure (which would change cwd).
   echo "${0##*/}: WARNING: ignoring extra args (env vars already set by parent build context): ${forwarded_args[*]}" >&2
fi

## ----------------------------------------------------------------------------
## Colors
## ----------------------------------------------------------------------------
##
## Source 'colors' if not already sourced. The 'colors' function early-returns
## when TERM is empty (e.g. CI, redirected output), leaving the format
## variables unset. Default them to empty strings so references below are safe.
if [ -z "${dist_build_already_defined_colors:-}" ]; then
   source "$MYDIR/colors"
   colors
fi
: "${bold:=}" "${red:=}" "${cyan:=}" "${under:=}" "${eunder:=}" "${reset:=}"

die() {
   printf '%s\n' "${bold}${red}${0##*/}: ERROR: $*${reset}" >&2
   exit 1
}

## ----------------------------------------------------------------------------
## Env var validation (all REQUIRED, no implicit defaults)
## ----------------------------------------------------------------------------

[ -n "${sq_git_policy_file:-}" ]            || die "env var sq_git_policy_file must be set"
[ -n "${sq_git_trust_root:-}" ]             || die "env var sq_git_trust_root must be set"
[ -n "${dist_build_ignore_untagged:-}" ]    || die "env var dist_build_ignore_untagged must be set ('true' or 'false')"
[ -n "${dist_build_ignore_uncommitted:-}" ] || die "env var dist_build_ignore_uncommitted must be set ('true' or 'false')"

case "${dist_build_ignore_untagged}" in
   true|false) ;;
   *) die "dist_build_ignore_untagged must be 'true' or 'false', got: '${dist_build_ignore_untagged}'" ;;
esac
case "${dist_build_ignore_uncommitted}" in
   true|false) ;;
   *) die "dist_build_ignore_uncommitted must be 'true' or 'false', got: '${dist_build_ignore_uncommitted}'" ;;
esac

trust_root="${sq_git_trust_root}"

## ----------------------------------------------------------------------------
## Verification primitives
## ----------------------------------------------------------------------------

## sq-git allows offloading the complexity of OpenPGP signing key import.
## File 'openpgp-policy.toml' contains authorized signing key(s) and supports
## multiple authorized signers natively.
sq_git_verify() {
   local target="$1"
   local label="$2"
   if sq-git log --policy-file "${sq_git_policy_file}" --trust-root "${trust_root}" -- "${target}"; then
      true "INFO: sq-git verification ok: ${label}"
      return 0
   fi
   echo "${bold}${red}ERROR: sq-git verification failed: ${label}${reset}" >&2
   echo "${cyan}INFO: If this is intentional, configure your own sq-git policy file." >&2
   echo "${cyan}      See 'buildconfig.d/30_signing_key.conf'.${reset}" >&2
   return 1
}

print_allow_hint() {
   echo "${cyan}INFO: As a developer or advanced user you might want to use:" >&2
   echo "${under}WARNING:${eunder} This can be ${under}insecure${eunder} if you cannot audit the changes." >&2
   echo "${bold}${under}--allow-untagged true${eunder} ${under}--allow-uncommitted true${eunder}${reset}" >&2
}

## ----------------------------------------------------------------------------
## Modes
## ----------------------------------------------------------------------------

mode_working_tree() {
   [ -n "$context" ] || die "--context is required for --mode working-tree"

   local head git_tag_exact git_status

   head="$(git rev-parse HEAD)" || die "Failed to get HEAD for: ${context}"

   ## 1. Commit signature.
   sq_git_verify "${head}^{commit}" "${context} (commit ${head})" || exit 1

   ## If HEAD is an exact tag, also verify the tag object signature.
   ## Policy: All git tags are always signed.
   git_tag_exact="$(git describe --exact-match --tags HEAD 2>/dev/null)" || true
   if [ -n "${git_tag_exact}" ]; then
      sq_git_verify "${git_tag_exact}" "${context} tag '${git_tag_exact}'" || exit 1
   fi

   ## 2. Untagged commit check.
   if [ -z "${git_tag_exact}" ]; then
      if [ "${dist_build_ignore_untagged}" = "true" ]; then
         echo "${cyan}INFO: Untagged commit in ${context}, --allow-untagged set, continuing.${reset}"
      else
         echo "${bold}${red}ERROR: Untagged commit in: ${context}${reset}" >&2
         print_allow_hint
         echo "${cyan}INFO: See build documentation on how to verify and checkout git tags.${reset}" >&2
         exit 2
      fi
   fi

   ## 3. Uncommitted changes check.
   git_status="$(git status --porcelain=v1 2>&1)"
   if [ -n "$git_status" ]; then
      if [ "${dist_build_ignore_uncommitted}" = "true" ]; then
         echo "${cyan}INFO: Uncommitted changes in ${context}, --allow-uncommitted set, continuing.${reset}"
         git status
      else
         echo "${bold}${red}ERROR: Uncommitted changes in: ${context}${reset}" >&2
         git status >&2
         print_allow_hint
         echo "${cyan}INFO: Running 'git clean -d --force --force --dry-run' for your convenience:${reset}" >&2
         git clean -d --force --force --dry-run >&2 || true
         if [ -n "${dist_source_help_steps_folder:-}" ]; then
            echo "${cyan}You most likely like to run:${reset}" >&2
            echo "${under}${dist_source_help_steps_folder}/cleanup-files${eunder}" >&2
            echo "${cyan}or if you know what you are doing:${reset}" >&2
            echo "${under}git clean -d --force --force${eunder}" >&2
            echo "${under}git reset --hard${eunder}" >&2
         fi
         exit 3
      fi
   fi
}

mode_ref() {
   [ -n "$ref" ]      || die "--ref is required for --mode ref"
   [ -n "$ref_type" ] || die "--ref-type is required for --mode ref"
   case "$ref_type" in
      tag|commit) ;;
      *) die "--ref-type must be 'tag' or 'commit'" ;;
   esac

   ## Always verify the commit signature.
   sq_git_verify "${ref}^{commit}" "ref '${ref}' (commit)" || exit 1

   ## For tags, also verify the tag object signature.
   ## NOTE: Not using 'refs/tags/' prefix here. The caller is responsible for
   ## passing an unambiguous ref. sq-git resolves it via the local repo.
   if [ "$ref_type" = 'tag' ]; then
      sq_git_verify "${ref}" "ref '${ref}' (tag object)" || exit 1
   fi
}

mode_submodules() {
   ## Comprehensive submodule checks via 'git submodule foreach --recursive'.
   ## Handles nested submodules, paths with special characters, moved paths.
   ##
   ## Submodule repositories intentionally do not include their own 'sq-git'
   ## policy file ('openpgp-policy.toml'). The parent repo's policy file is
   ## used for all verification, keeping signing policy centralized.
   ##
   ## NOTE: 'git submodule foreach' runs commands under /bin/sh, not bash.
   ## We re-invoke this script (under bash) per submodule to keep strict
   ## shell options and shared verification logic.
   ##
   ## '$toplevel' is safe for nested submodules: git sets it via xgetcwd()
   ## at foreach start, so it always points to the root superproject.
   ## https://github.com/git/git/blob/master/builtin/submodule--helper.c
   ## (function runcommand_in_submodule_cb: toplevel = xgetcwd())
   sq_git_trust_root=HEAD \
      git submodule foreach --recursive \
         'bash "$toplevel/help-steps/git_sanity_test" --mode working-tree --context "$displaypath"'
}

mode_all() {
   [ -n "$context" ] || die "--context is required for --mode all"
   mode_working_tree
   mode_submodules
}

case "$mode" in
   working-tree) mode_working_tree ;;
   ref)          mode_ref ;;
   submodules)   mode_submodules ;;
   all)          mode_all ;;
   *) die "unknown mode '$mode' (working-tree | ref | submodules | all)" ;;
esac
