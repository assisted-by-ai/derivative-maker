# shellcheck source=../packages/kicksecure/helper-scripts/usr/libexec/helper-scripts/check_runtime.bsh
source "$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )/../packages/kicksecure/helper-scripts/usr/libexec/helper-scripts/check_runtime.bsh"

if was_executed "${BASH_SOURCE[0]}"; then
   git_sanity_test_was_sourced='false'
else
   git_sanity_test_was_sourced='true'
fi

if [ "${git_sanity_test_was_sourced}" = 'false' ]; then
   set -x
   set -e

   true "INFO: Currently running script: $BASH_SOURCE $@"

   MYDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

   cd "$MYDIR"
   cd ..
   cd help-steps

   dist_build_internal_run="true"

   source pre
   source colors
   source variables
fi

signed_by_fingerprint() {
  command -v sq-git >/dev/null

  cmd=( sq-git log --policy-file "${sq_git_policy_file}" --trust-root "${sq_git_trust_root}" -- "${1}" )

  ## sq-git allows to offload the complexity of OpenPGP signing key import.
  ## File 'openpgp-policy.toml' contains authorized signing key(s).
  if "${cmd[@]}"; then
    true "INFO: sq-git verification, ok."
    return 0
  fi

  1>&2 printf '%s\n' "\
WARNING: sq-git verification command failed!

sq-git verification command:
${cmd[*]}

(INFO: If this is intentional, could:
- A) preferably: configure your own sq-git policy file, see file 'buildconfig.d/30_signing_key.conf'; or,
- B) crude: out-comment this check.)"
  ## This can be skipped by replacing 'return 1' with 'return 0'.
  return 1
}

verify_ref() {
  local ref ref_type

  ref="${1:-}"
  ref_type="${2:-}"

  if [ -z "${ref}" ]; then
    error 'Cannot pass empty ref to verify_ref!'
  fi
  if [ -z "${ref_type}" ]; then
    error 'Cannot pass empty ref_type to verify_ref!'
  fi
  case "${ref_type}" in
    tag|commit)
      true "INFO: ref_type: tag or commit."
      ;;
    *)
      error "ref_type must be one of 'tag' or 'commit'!"
      ;;
  esac

  ## Policy: All git commits (at least HEAD) is always signed.
  signed_by_fingerprint "${ref}^{commit}" || return 1

  if [ "${ref_type}" = 'tag' ]; then
    ## Policy: All git tags are always signed.
    ##
    ## NOTE: 'refs/tags/' is necessary to prevent ambiguity in the event of a
    ## tag with the same name as a branch or commit.
    signed_by_fingerprint "${ref}" || return 1
  fi
}

git_sanity_test_hint() {
   true "${cyan}$BASH_SOURCE INFO: As a developer or advanced user you might want to use:${reset}
${cyan}${under}WARNING:${eunder}${reset} This can be ${under}insecure${eunder} if you are unable to audit the uncommitted changes.
${bold}${under}--allow-untagged true${eunder} ${under}--allow-uncommitted true${eunder}${reset}
"
}

git_sanity_test_submodules() {
   ## Comprehensive submodule checks: signature, untagged, uncommitted.
   ## Uses 'git submodule foreach --recursive' for robustness (handles nested
   ## submodules, paths with special characters, moved submodules).
   ##
   ## Submodule repositories intentionally do not include their own 'sq-git'
   ## policy file ('openpgp-policy.toml'). A single policy file in the parent
   ## repository ('derivative-maker') is used for all verification, keeping
   ## signing policy centralized and avoiding duplication across repositories.
   ##
   ## NOTE: 'git submodule foreach' runs commands under /bin/sh, not bash.
   ## Using a separate bash helper script ('git_sanity_test_one') to get
   ## strict shell options (set -e, pipefail, nounset), colored output, and
   ## shared verification logic with the main repo check.
   sq_git_trust_root=HEAD \
      git submodule foreach --recursive \
         'bash "$toplevel/help-steps/git_sanity_test_one" "$displaypath"'
}

git_sanity_test_main() {
   ## Main repo: run the same checks as submodules (signature, untagged,
   ## uncommitted) via the shared helper script, then print verbose recovery
   ## hints if any check failed.
   ##
   ## TOFU threat model: Initial digital software verification must be done
   ## manually for stronger-than-TOFU security. See:
   ## https://www.kicksecure.com/wiki/Dev/Build_Documentation/images
   local test_one_exit_code=0
   "$dist_source_help_steps_folder/git_sanity_test_one" "main repo" || test_one_exit_code=$?

   if [ "$test_one_exit_code" != "0" ]; then
      ## Verbose hints for interactive main repo use.
      git_sanity_test_hint
      case "$test_one_exit_code" in
         2)
            ## Untagged.
            true "${cyan}$BASH_SOURCE INFO: (See build documentation on how to verify and checkout git tags.)${reset}"
            error "Untagged commit! See above!"
            ;;
         3)
            ## Uncommitted.
            true "${cyan}$BASH_SOURCE INFO: Running git \"clean -d --force --force --dry-run\" for your convenience. ${reset}"
            git clean -d --force --force --dry-run
            true "${cyan}$BASH_SOURCE You most likely like to run:${reset}
${under}$dist_source_help_steps_folder/cleanup-files${eunder}
${cyan}or if you know what you are doing:${reset}
${under}git clean -d --force --force${eunder}
${under}git reset --hard${eunder}
"
            error "Uncommitted changes! See above!"
            ;;
         *)
            ## Signature or other failure.
            error "Verification failed for main repo! See above!"
            ;;
      esac
   fi

   git_sanity_test_submodules
}

if [ "${git_sanity_test_was_sourced}" = 'false' ]; then
   main() {
      git_sanity_test_main "$@"
   }
   main "$@"
fi
